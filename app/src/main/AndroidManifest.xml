<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logoimc"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logoimc"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <activity
            android:name=".meal_reservation.MealReservationApplicantLoginActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".meal_reservation.MealReservationApplicantIdentificationActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationApplicantLoginActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".meal_reservation.MealReservationApplicantDateActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationApplicantIdentificationActivity" />

        <activity
            android:name=".meal_reservation.MealReservationApplicantProductCatalogueActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationApplicantDateActivity" />

        <activity
            android:name=".meal_reservation.MealReservationApplicantReservationBasketActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationApplicantProductCatalogueActivity" />

        <activity
            android:name=".meal_reservation.MealReservationApplicantNumActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationApplicantReservationBasketActivity" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurLoginActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurDashboardActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurLoginActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurCatalogManagementActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurDashboardActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurProductFormActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurCatalogManagementActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurScheduleManagementActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurDashboardActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurOrdersListActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurDashboardActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurOrderDetailActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurOrdersListActivity" />

        <activity
            android:name=".meal_reservation.MealReservationRestaurateurOrdersHistoryActivity"
            android:exported="false"
            android:parentActivityName=".meal_reservation.MealReservationRestaurateurOrdersListActivity" />
    </application>

</manifest>