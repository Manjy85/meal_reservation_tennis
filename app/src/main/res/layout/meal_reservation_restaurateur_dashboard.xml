<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prussian_blue">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarRestaurateurDashboard"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/prussian_blue"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewDashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panneau restaurateur"
        android:textColor="@color/amber_honey"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/toolbarRestaurateurDashboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/toolbarRestaurateurDashboard"
        android:layout_marginStart="16dp" />

    <ImageButton
        android:id="@+id/btnLogoutDashboard"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@android:color/transparent"
        android:contentDescription="Se deconnecter"
        android:padding="8dp"
        android:src="@android:drawable/ic_lock_power_off"
        app:tint="@color/amber_honey"
        app:layout_constraintBottom_toBottomOf="@+id/toolbarRestaurateurDashboard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/toolbarRestaurateurDashboard" />

    <TextView
        android:id="@+id/textViewDashboardDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:text="Acces rapide a la gestion du catalogue, des horaires d'evenements et des commandes."
        android:textAlignment="center"
        android:textColor="@color/amber_honey"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbarRestaurateurDashboard" />

    <LinearLayout
        android:id="@+id/dashboardActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewDashboardDesc">

        <Button
            android:id="@+id/btnGoCatalogueManagement"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#333333"
            android:text="Gestion du catalogue"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnGoScheduleManagement"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#333333"
            android:text="Dates et plages horaires"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnGoOrdersManagement"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#333333"
            android:text="Consultation des commandes"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

