<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/prussian_blue">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarCatalogueManagement"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/prussian_blue"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewCatalogueManagementTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestion du catalogue"
        android:textColor="@color/amber_honey"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/toolbarCatalogueManagement"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/toolbarCatalogueManagement"
        android:layout_marginStart="16dp" />

    <ImageButton
        android:id="@+id/btnLogoutCatalogueManagement"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@android:color/transparent"
        android:contentDescription="Se deconnecter"
        android:padding="8dp"
        android:src="@android:drawable/ic_lock_power_off"
        app:tint="@color/amber_honey"
        app:layout_constraintBottom_toBottomOf="@+id/toolbarCatalogueManagement"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/toolbarCatalogueManagement" />

    <LinearLayout
        android:id="@+id/filterContainerCatalogue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="#1AFFFFFF"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbarCatalogueManagement">

        <EditText
            android:id="@+id/editTextSearchProduct"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:backgroundTint="@color/amber_honey"
            android:hint="Rechercher un produit"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="#66FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/spinnerProductCategory"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:backgroundTint="@color/amber_honey"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Afficher inactifs"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/switchShowInactive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:thumbTint="@color/amber_honey"
                android:trackTint="#66FFFFFF" />

        </LinearLayout>

        <Button
            android:id="@+id/btnAddProduct"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#333333"
            android:text="Ajouter un produit"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewProducts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filterContainerCatalogue" />

</androidx.constraintlayout.widget.ConstraintLayout>

